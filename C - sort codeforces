#include <bits/stdc++.h>
#define int long long
#define db double
#define yes "YES\n"
#define no "NO\n"
#define all(v) v.begin(),v.end()
#define rall(v) v.rbegin(), v.rend()
using namespace std;

void solve(){
    int n , q ; cin >> n >> q ; 
    string a , b ; cin >> a >> b ; 

    vector<vector<int>> prefA(n + 1 , vector<int>(26 , 0)) ; 
    vector<vector<int>> prefB(n + 1 , vector<int>(26 , 0)) ; 

    int ans = 0 ;
    int cnt = 0 ; 

    for(int i = 0 ; i < n ; ++i) {
        prefA[i + 1] = prefA[i] ; 
        prefB[i + 1] = prefB[i] ; 
        
        prefA[i + 1][a[i] - 'a']++ ;
        prefB[i + 1][b[i] - 'a']++ ;

    }

    while(q--) {
        int l , r ; cin >> l >> r ;
        ans = 0 ; 
        for(int i = 0 ; i < 26 ; ++i) { 
            int cntA = prefA[r][i] - prefA[l - 1][i] ; 
            int cntb = prefB[r][i] - prefB[l - 1][i] ; 
            ans += abs(cntA - cntb) ; 
        }
        cout << ans / 2 << "\n" ;
    }
}

int32_t main(){
   ios::sync_with_stdio(false);
   cin.tie(nullptr);
    
    int gas = 1;
    cin >> gas; 
    while(gas--) solve();

    return pow(1-1, 2);
}
