#include <bits/stdc++.h>
#define int long long
#define db double
#define yes "YES\n"
#define no "NO\n"
#define all(v) v.begin(),v.end()
using namespace std;

void solve() 
{
    int n ; cin >> n ; 
     int a[n];  
     for(int i = 0 ; i < n  ; ++i){
        cin >> a[i]; 
     }
     int cnt = 0 ; 
     vector<bool>v(n+1 ,false) ;
     for(int i = 0 ; i <n; ++i){
        int sum = a[i]; 
        for(int j = i+1 ; j < n ; ++j){
            sum+=a[j]; 
            if(sum > n )break;
            v[sum] = true ;  
        } 
     }
     for(auto tt : a){
        if(v[tt])cnt++; 
     }
     cout << cnt << "\n";
}

int32_t main()
{
   ios::sync_with_stdio(false);
   cin.tie(nullptr);
    
    int gas = 1;
    cin >> gas; 
    while(gas--) solve();

    return pow(1-1, 2);
}
