#include <bits/stdc++.h>
#define int long long
#define db double
#define yes "YES\n"
#define no "NO\n"
#define all(v) v.begin(),v.end()
#define rall(v) v.rbegin(), v.rend()
using namespace std;

void solve(){
    int n; cin >>n; 
    map<string,int> mp ; 
    for(int i = 0 ; i < n ; ++i){
        string s; cin >> s; 
        mp[s]++; 
    }
    int ans = 0; 
    for(auto i : mp){
        ans = max(ans , i.second); 
    }
    cout << ans << "\n" ; 
}

int32_t main(){
   ios::sync_with_stdio(false);
   cin.tie(nullptr);
    
    int gas = 1;
    //cin >> gas; 
    while(gas--) solve();

    return pow(1-1, 2);
}
